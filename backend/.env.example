# Copy to .env and fill in. Never commit .env.

# Signs JWTs. Required in production - the app raises at import without it.
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Set to "production" to enforce the SECRET_KEY check above.
ENV=development

# Defaults to sqlite:///./typing.db
# DATABASE_URL=
