        </mxCell>
        <mxCell id="k7" edge="1" parent="1" source="l_keydown" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=0;entryX=0.5;entryY=1;dashed=1;" target="l_state" value="mutate state">
