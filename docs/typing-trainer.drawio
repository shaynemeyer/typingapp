        <mxCell id="l_user" value="User&#xa;(keydown, clicks)" style="shape=umlActor;whiteSpace=wrap;html=1;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="l_browser">
          <mxGeometry x="90" y="50" width="40" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="l_raf" value="requestAnimationFrame&#xa;(60 fps ticks)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="l_browser">
          <mxGeometry x="40" y="180" width="150" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="l_ls" value="localStorage&#xa;JWT only&#xa;(scores live on the server)" style="shape=cylinder3;boundedLbl=1;whiteSpace=wrap;html=1;backgroundOutline=1;size=12;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="l_browser">
          <mxGeometry x="45" y="270" width="140" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="l_react" value="React (frontend/src)" style="swimlane;whiteSpace=wrap;html=1;startSize=25;fillColor=none;strokeColor=#6c8ebf;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="310" y="40" width="330" height="780" as="geometry"/>
        </mxCell>
        <mxCell id="l_app" value="App.tsx&#xa;owns passage, user, results" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="l_react">
          <mxGeometry x="50" y="45" width="230" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="l_typing" value="useTyping()&#xa;status[] array is the character state&#xa;(in the old app the spans WERE the state)&#xa;position, typed, wrong, startTime, finished" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="l_react">
          <mxGeometry x="25" y="135" width="280" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="l_scoring" value="lib/scoring.ts&#xa;wpm = (typed / 5) / minutes&#xa;accuracy = (typed - wrong) / typed&#xa;counters only ever increase" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="l_react">
          <mxGeometry x="25" y="260" width="280" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="l_scroll" value="useAutoScroll()&#xa;reads wpm through a ref&#xa;(a closure would freeze at 60)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="l_react">
          <mxGeometry x="35" y="375" width="260" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="l_passagec" value="Passage.tsx&#xa;maps status[] to span classes:&#xa;current / correct / wrong" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="l_react">
          <mxGeometry x="35" y="480" width="260" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="l_authc" value="Auth.tsx / History.tsx" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="l_react">
          <mxGeometry x="65" y="585" width="200" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="l_client" value="api/client.ts&#xa;typed fetch wrapper&#xa;attaches Bearer token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="l_react">
          <mxGeometry x="50" y="670" width="230" height="70" as="geometry"/>
