        <mxCell id="h_stepback" value="Step cursor back,&#xa;clear the color&#xa;(score unchanged)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="610" y="415" width="180" height="70" as="geometry"/>
