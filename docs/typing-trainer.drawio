        <mxCell id="e5" value="Backspace" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="h_wait" target="h_backcheck">
          <mxGeometry relative="1" as="geometry" />
