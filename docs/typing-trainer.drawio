<mxfile host="Electron" pages="2">
  <diagram id="highlevel" name="High-Level Flow">
    <mxGraphModel adaptiveColors="auto" dx="1100" dy="800" grid="1" gridSize="10" page="1" pageWidth="850" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="h_start" value="Open index.html" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="320" y="20" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h_render" value="Ready&#xa;Pick random passage, render one span per character,&#xa;highlight first character, seed stats at 60 wpm / 100%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="270" y="110" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="h_wait" value="User presses a key" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="320" y="220" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="h_ignore" value="Ignore&#xa;(Shift, arrows, Ctrl...)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="230" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="h_backcheck" value="Any characters&#xa;typed yet?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="610" y="220" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="h_stepback" value="Step cursor back,&#xa;clear that character&#39;s color&#xa;(score stays unchanged)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="600" y="350" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="h_clock" value="Typing&#xa;Start the clock on the first character key" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="290" y="350" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="h_match" value="Matches the expected&#xa;character?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="310" y="450" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="h_correct" value="Mark character correct" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="80" y="470" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h_wrong" value="Mark character wrong&#xa;count it against accuracy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="590" y="465" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="h_advance" value="Advance cursor, update live wpm and accuracy,&#xa;keep scrolling passage at typing speed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="270" y="590" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="h_done" value="Passage complete?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="320" y="690" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="h_results" value="Finished&#xa;Show results panel with final wpm and accuracy&#xa;Stop scrolling, ignore further typing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="270" y="830" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="h_choice" value="User clicks..." style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="330" y="950" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="h_save" value="Append run to localStorage&#xa;Download results.txt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="620" y="955" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="h_reload" value="Reload page&#xa;(new random passage, counters reset)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="40" y="950" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="h_start" target="h_render">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="h_render" target="h_wait">
          <mxGeometry relative="1" as="geometry" />
