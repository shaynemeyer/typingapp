  <diagram id="lowlevel" name="Low-Level Interaction">
    <mxGraphModel adaptiveColors="auto" dx="1100" dy="800" grid="1" gridSize="10" page="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="l_browser" value="Browser" style="swimlane;whiteSpace=wrap;html=1;startSize=25;fillColor=none;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
