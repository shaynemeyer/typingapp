<mxfile host="app.diagrams.net" pages="3">
  <diagram id="highlevel" name="High-Level Flow">
    <mxGraphModel adaptiveColors="auto" dx="1100" dy="800" grid="1" gridSize="10" page="1" pageWidth="850" pageHeight="1450" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="h_start" value="Open the app" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="330" y="20" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="h_fetch" value="GET /api/passages/next" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="320" y="105" width="200" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="h_render" value="Ready&#xa;Render passage, highlight first character,&#xa;seed stats at 60 wpm / 100%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="280" y="185" width="280" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="h_wait" value="User presses a key" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
