  <diagram id="api" name="API and Data Model">
    <mxGraphModel adaptiveColors="auto" dx="1100" dy="800" grid="1" gridSize="10" page="1" pageWidth="1100" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="a_title" value="Endpoints" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="200" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="a_open" value="Open (no auth)" style="swimlane;whiteSpace=wrap;html=1;startSize=30;fillColor=none;strokeColor=#82b366;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="290" height="240" as="geometry"/>
        </mxCell>
        <mxCell id="a_reg" value="POST /api/register&#xa;create account, returns JWT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="a_open">
          <mxGeometry x="20" y="45" width="250" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="a_tok" value="POST /api/token&#xa;log in, returns JWT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="a_open">
          <mxGeometry x="20" y="105" width="250" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="a_next" value="GET /api/passages/next&#xa;GET /api/passages" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="a_open">
          <mxGeometry x="20" y="165" width="250" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="a_jwt" value="Requires JWT" style="swimlane;whiteSpace=wrap;html=1;startSize=30;fillColor=none;strokeColor=#9673a6;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="330" width="290" height="290" as="geometry"/>
        </mxCell>
        <mxCell id="a_pcrud" value="POST /api/passages&#xa;PUT /api/passages/{id}&#xa;DELETE /api/passages/{id}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="a_jwt">
          <mxGeometry x="20" y="45" width="250" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="a_res" value="POST /api/results&#xa;owner taken from the token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="a_jwt">
          <mxGeometry x="20" y="130" width="250" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="a_hist" value="GET /api/users/me/results&#xa;only your own history" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="a_jwt">
          <mxGeometry x="20" y="195" width="250" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="a_dtitle" value="Data model" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="480" y="20" width="200" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="a_user" value="User" style="swimlane;whiteSpace=wrap;html=1;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="480" y="70" width="220" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="a_user_f" value="id (PK)&#xa;username (unique)&#xa;hashed_password (argon2)&#xa;created_at" style="text;html=1;align=left;verticalAlign=top;fillColor=none;strokeColor=none;" vertex="1" parent="a_user">
          <mxGeometry x="10" y="35" width="200" height="85" as="geometry"/>
        </mxCell>

        <mxCell id="a_passage" value="Passage" style="swimlane;whiteSpace=wrap;html=1;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="820" y="70" width="220" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="a_passage_f" value="id (PK)&#xa;text&#xa;created_at&#xa;&#xa;3 seeded on startup" style="text;html=1;align=left;verticalAlign=top;fillColor=none;strokeColor=none;" vertex="1" parent="a_passage">
          <mxGeometry x="10" y="35" width="200" height="85" as="geometry"/>
        </mxCell>

        <mxCell id="a_result" value="Result" style="swimlane;whiteSpace=wrap;html=1;startSize=30;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="650" y="330" width="240" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="a_result_f" value="id (PK)&#xa;user_id (FK -&gt; user.id)&#xa;passage_id (FK -&gt; passage.id)&#xa;wpm&#xa;accuracy (0-100)&#xa;created_at" style="text;html=1;align=left;verticalAlign=top;fillColor=none;strokeColor=none;" vertex="1" parent="a_result">
          <mxGeometry x="10" y="35" width="220" height="115" as="geometry"/>
        </mxCell>

        <mxCell id="a_note" value="A Result's user_id comes from the JWT,&#xa;never from the request body - a client&#xa;cannot write into another user's history." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="620" y="540" width="300" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="ae1" value="1 : many" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.25;entryY=0;startArrow=none;endArrow=block;" edge="1" parent="1" source="a_user" target="a_result">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="590" y="270"/>
              <mxPoint x="710" y="270"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="ae2" value="1 : many" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.75;entryY=0;startArrow=none;endArrow=block;" edge="1" parent="1" source="a_passage" target="a_result">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="930" y="270"/>
              <mxPoint x="830" y="270"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="ae3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=0;entryX=0.5;entryY=1;dashed=1;endArrow=none;" edge="1" parent="1" source="a_note" target="a_result">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
