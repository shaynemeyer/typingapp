        <mxCell id="k2" edge="1" parent="1" source="l_user" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=0.5;entryX=0;entryY=0.5;exitDx=0;exitDy=0;exitPerimeter=0;" target="l_save" value="click #save-btn">
          <mxGeometry relative="1" as="geometry">
