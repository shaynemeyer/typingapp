        <mxCell id="e9" value="character key" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="h_wait" target="h_clock">
          <mxGeometry relative="1" as="geometry" />
