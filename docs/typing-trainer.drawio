        <mxCell id="e6" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="h_backcheck" target="h_stepback">
          <mxGeometry relative="1" as="geometry" />
