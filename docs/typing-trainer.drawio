  </diagram>
  <diagram id="lowlevel" name="Low-Level Interaction">
    <mxGraphModel dx="1094" dy="876" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="900" math="0" shadow="0" adaptiveColors="auto">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="l_browser" parent="1" style="swimlane;whiteSpace=wrap;html=1;startSize=25;fillColor=none;strokeColor=#666666;dashed=1;" value="Browser" vertex="1">
          <mxGeometry height="330" width="300" x="50" y="30" as="geometry" />
        </mxCell>
        <mxCell id="l_raf" parent="l_browser" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" value="requestAnimationFrame&#xa;(60 fps ticks)" vertex="1">
          <mxGeometry height="60" width="140" x="140" y="50" as="geometry" />
        </mxCell>
        <mxCell id="l_ls" parent="l_browser" style="shape=cylinder3;boundedLbl=1;whiteSpace=wrap;html=1;backgroundOutline=1;size=12;fillColor=#ffe6cc;strokeColor=#d79b00;" value="localStorage&#xa;key: typingResults" vertex="1">
          <mxGeometry height="80" width="120" x="30" y="180" as="geometry" />
        </mxCell>
        <mxCell id="l_dl" parent="l_browser" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="Blob + object URL&#xa;download results.txt" vertex="1">
          <mxGeometry height="70" width="110" x="170" y="185" as="geometry" />
        </mxCell>
        <mxCell id="l_dom" parent="1" style="swimlane;whiteSpace=wrap;html=1;startSize=25;fillColor=none;strokeColor=#6c8ebf;dashed=1;" value="index.html — DOM" vertex="1">
          <mxGeometry height="420" width="290" x="770" y="30" as="geometry" />
        </mxCell>
        <mxCell id="l_json" parent="l_dom" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="script#passages&#xa;(JSON, 3 passages)" vertex="1">
          <mxGeometry height="50" width="170" x="60" y="40" as="geometry" />
        </mxCell>
        <mxCell id="l_passage" parent="l_dom" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="div#passage&#xa;one span.char per character&#xa;classes: current / correct / wrong" vertex="1">
          <mxGeometry height="70" width="210" x="40" y="115" as="geometry" />
        </mxCell>
        <mxCell id="l_viewport" parent="l_dom" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="div#passage-viewport&#xa;scrollTop" vertex="1">
          <mxGeometry height="50" width="170" x="60" y="210" as="geometry" />
        </mxCell>
        <mxCell id="l_livestats" parent="l_dom" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="span#wpm-live&#xa;span#accuracy-live" vertex="1">
          <mxGeometry height="50" width="170" x="60" y="285" as="geometry" />
        </mxCell>
        <mxCell id="l_resultsel" parent="l_dom" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="section#results (.hidden)&#xa;#wpm-final, #accuracy-final&#xa;#save-btn, #restart-btn" vertex="1">
          <mxGeometry height="55" width="210" x="40" y="355" as="geometry" />
        </mxCell>
        <mxCell id="l_app" parent="1" style="swimlane;whiteSpace=wrap;html=1;startSize=25;fillColor=none;strokeColor=#82b366;dashed=1;" value="app.js" vertex="1">
          <mxGeometry height="820" width="330" x="390" y="30" as="geometry" />
        </mxCell>
        <mxCell id="l_state" parent="l_app" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Module state&#xa;position, typed, wrong&#xa;startTime, finished, wpm&#xa;passage (random pick)" vertex="1">
          <mxGeometry height="80" width="200" x="65" y="40" as="geometry" />
        </mxCell>
        <mxCell id="l_render" parent="l_app" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="renderPassage()&#xa;build spans, mark first current" vertex="1">
          <mxGeometry height="55" width="230" x="50" y="150" as="geometry" />
        </mxCell>
        <mxCell id="l_keydown" parent="l_app" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="handleKeydown(e)&#xa;bail if finished; Backspace rewinds;&#xa;non-character keys ignored;&#xa;first character key sets startTime;&#xa;compare, class, position += 1" vertex="1">
          <mxGeometry height="100" width="260" x="35" y="240" as="geometry" />
        </mxCell>
        <mxCell id="l_update" parent="l_app" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="updateLiveStats()" vertex="1">
          <mxGeometry height="40" width="160" x="85" y="375" as="geometry" />
        </mxCell>
        <mxCell id="l_calc" parent="l_app" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" value="currentWpm() = (typed / 5) / minutes&#xa;currentAccuracy() = (typed - wrong) / typed" vertex="1">
          <mxGeometry height="55" width="260" x="35" y="445" as="geometry" />
        </mxCell>
        <mxCell id="l_scroll" parent="l_app" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="scrollTick()&#xa;scrollTop += f(wpm); re-arms itself" vertex="1">
          <mxGeometry height="55" width="230" x="50" y="530" as="geometry" />
        </mxCell>
        <mxCell id="l_finish" parent="l_app" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="finish()&#xa;finished = true; write final stats;&#xa;unhide results panel" vertex="1">
          <mxGeometry height="70" width="230" x="50" y="620" as="geometry" />
        </mxCell>
        <mxCell id="l_save" parent="l_app" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="saveResult()&#xa;append TSV line, persist, download" vertex="1">
          <mxGeometry height="60" width="230" x="50" y="725" as="geometry" />
        </mxCell>
        <mxCell id="k1" edge="1" parent="1" source="l_user" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=0;entryX=0;entryY=0.5;exitDx=0;exitDy=0;exitPerimeter=0;" target="l_keydown" value="keydown">
          <mxGeometry relative="1" as="geometry">
