            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="k4" edge="1" parent="1" source="l_state" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.25;entryX=0;entryY=0.5;dashed=1;" target="l_json" value="parse JSON, pick one">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="k5" edge="1" parent="1" source="l_render" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" target="l_passage" value="append spans">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="k6" edge="1" parent="1" source="l_keydown" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.75;" target="l_passage" value="toggle char classes">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="745" y="320" />
