        <mxCell id="e12" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="h_match" target="h_wrong">
          <mxGeometry relative="1" as="geometry" />
